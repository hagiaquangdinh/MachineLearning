import pandas as pd
import joblib
import os
from scikit-learn.cluster import KMeans
from scikit-learn.preprocessing import StandardScaler

# 1 & 2. Đọc và tiền xử lý (như cũ)
df = pd.read_csv('Train.csv')
data = df[['Age', 'Spending_Score']].dropna().copy()
score_mapping = {'Low': 1, 'Average': 2, 'High': 3}
data['Spending_Score_Num'] = data['Spending_Score'].map(score_mapping)
X = data[['Age', 'Spending_Score_Num']]

# 3. Chuẩn hóa & Huấn luyện 
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)

kmeans = KMeans(n_clusters=3, random_state=42, n_init=10)
kmeans.fit(X_scaled)

# 4. ĐÓNG GÓI VÀ LƯU THÀNH 1 FILE DUY NHẤT
os.makedirs('models', exist_ok=True)

# Tạo một "chiếc hộp" (dictionary) chứa cả 2 thứ
model_artifacts = {
    'kmeans': kmeans
}

# Lưu chiếc hộp này thành 1 file tên là model.pkl
joblib.dump(model_artifacts, 'models/model.pkl')
print("Đã gộp chung Scaler và K-Means vào 1 file models/model.pkl thành công!")