# Tên file: train_and_save_model.py
import pandas as pd
import joblib
import os
from sklearn.cluster import KMeans
from sklearn.preprocessing import StandardScaler

# 1. Đọc dữ liệu
df = pd.read_csv('Train.csv')
data = df[['Age', 'Spending_Score']].dropna().copy()

# 2. Xử lý logic giống hệt lúc huấn luyện
score_mapping = {'Low': 1, 'Average': 2, 'High': 3}
data['Spending_Score_Num'] = data['Spending_Score'].map(score_mapping)
X = data[['Age', 'Spending_Score_Num']]

# 3. Chuẩn hóa & Huấn luyện (Giả sử K=3)
scaler = StandardScaler()
X_scaled = scaler.fit_transform(X)

kmeans = KMeans(n_clusters=3, random_state=42, n_init=10)
kmeans.fit(X_scaled)

# 4. Tạo thư mục models và lưu file .pkl
os.makedirs('models', exist_ok=True)
joblib.dump(scaler, 'models/scaler.pkl')
joblib.dump(kmeans, 'models/kmeans_model.pkl')
print("Đã lưu mô hình thành công vào thư mục models/!")